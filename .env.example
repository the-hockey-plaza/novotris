# Required environment variables for public/php/db.php
# Copy this file to .env (or configure variables in your web server/process manager)
# Note: NOVOTRIS_PW_SALT currently follows the existing crypt-based legacy logic.
# Optional: fixed database name (defaults to novotris_work)

NOVOTRIS_DB_USER=your_db_user
NOVOTRIS_DB_PASSWORD=your_db_password
NOVOTRIS_DB_NAME=novotris_work
NOVOTRIS_PW_SALT=$1$novotris$
